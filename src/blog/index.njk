---
layout: base.njk
title: Writing
description: GTM intelligence, ICP methodology, and signal theory for B2B SaaS founders.
permalink: /blog/
---

{% set featuredPost = collections.featured[0] or collections.posts[0] %}

<section class="page-header">
  <div class="ph-inner">
    <div class="ph-ew">Signal Resolution · Writing</div>
    <h1 class="ph-hl">THINKING.<br>OUT <em>LOUD.</em></h1>
    <p class="ph-sub">Authoritative frameworks, field-tested signal theory, and the unfiltered GTM thinking that most people aren't willing to publish. No content marketing. Just the ideas.</p>
  </div>
</section>

<section class="filter-bar">
  <div class="fb-inner inner">
    <div class="fb-label">Filter by category</div>
    <div class="fb-actions">
      <button class="filter-btn on" data-cat="all" onclick="filter('all', this)">All</button>
      <button class="filter-btn" data-cat="icp-methodology" onclick="filter('icp-methodology', this)">ICP Methodology</button>
      <button class="filter-btn" data-cat="signal-theory" onclick="filter('signal-theory', this)">Signal Theory</button>
      <button class="filter-btn" data-cat="psychographics" onclick="filter('psychographics', this)">Psychographics</button>
      <button class="filter-btn" data-cat="founder-gtm" onclick="filter('founder-gtm', this)">Founder GTM</button>
      <button class="filter-btn" data-cat="data-layer" onclick="filter('data-layer', this)">Data Layer</button>
    </div>
    <div class="search-wrap">
      <input id="blogSearch" class="search-input" type="search" placeholder="Search posts" oninput="search(this.value)">
      <span class="search-icon">&#8981;</span>
    </div>
  </div>
</section>

<section class="blog-main">
  <div class="bm-inner inner">
    {% if featuredPost %}
    <div class="featured-post" data-category="{{ featuredPost.data.category or 'GTM' }}">
      <a class="fp-card" href="{{ featuredPost.url }}" data-cat="{{ (featuredPost.data.category or 'gtm') | lower | replace(' ', '-') }}" data-title="{{ featuredPost.data.title | lower }}">
        <div class="fp-badge">Featured</div>
        <h2 class="fp-title">{{ featuredPost.data.title }}</h2>
        <p class="fp-excerpt">{{ featuredPost.data.description }}</p>
        <div class="fp-meta">{{ featuredPost.date | postDate }} · {{ featuredPost.content | readingTime }}</div>
      </a>
      <div class="fp-side">
        {% set sidePost1 = collections.posts[1] %}
        {% set sidePost2 = collections.posts[2] %}
        {% if sidePost1 %}
        <a href="{{ sidePost1.url }}" class="fp-side-card" data-cat="{{ sidePost1.data.category | lower | replace(' ', '-') }}" data-title="{{ sidePost1.data.title | lower }}">
          <div class="fsc-tag"><span class="fsc-tag-dot"></span>{{ sidePost1.data.category }}</div>
          <div class="fsc-title">{{ sidePost1.data.title }}</div>
          <div class="fsc-excerpt">{{ sidePost1.data.description }}</div>
          <div class="fsc-meta"><span>{{ sidePost1.date | postDate }} · {{ sidePost1.data.readTime }}</span><span class="fsc-read">Read &#8594;</span></div>
        </a>
        {% endif %}
        {% if sidePost2 %}
        <a href="{{ sidePost2.url }}" class="fp-side-card" data-cat="{{ sidePost2.data.category | lower | replace(' ', '-') }}" data-title="{{ sidePost2.data.title | lower }}">
          <div class="fsc-tag"><span class="fsc-tag-dot"></span>{{ sidePost2.data.category }}</div>
          <div class="fsc-title">{{ sidePost2.data.title }}</div>
          <div class="fsc-excerpt">{{ sidePost2.data.description }}</div>
          <div class="fsc-meta"><span>{{ sidePost2.date | postDate }} · {{ sidePost2.data.readTime }}</span><span class="fsc-read">Read &#8594;</span></div>
        </a>
        {% endif %}
      </div>
    </div>
    {% endif %}

    <div class="post-grid" id="postGrid">
      {% set count = 0 %}
      {% for post in collections.posts %}
        {% if not post.data.featured %}
        {% set count = count + 1 %}
        <a href="{{ post.url }}" class="post-card" data-title="{{ post.data.title | lower }}" data-cat="{{ (post.data.category or 'GTM') | lower | replace(' ', '-') }}">
          <div class="pc-tag"><span class="pc-tag-dot"></span>{{ post.data.category or 'GTM' }}</div>
          <div class="pc-title">{{ post.data.title }}</div>
          <div class="pc-excerpt">{{ post.data.description }}</div>
          <div class="pc-meta"><span>{{ post.date | postDate }} · {{ post.data.readTime }}</span><span class="pc-read">Read &#8594;</span></div>
        </a>
        {% endif %}
      {% endfor %}

      {% if count < 4 %}
      <article class="post-card placeholder" data-cat="placeholder">
        <div class="pc-tag"><span class="pc-tag-dot"></span>Coming next</div>
        <div class="pc-title">How to segment by buyer state</div>
        <div class="pc-excerpt">A practical model for changing messaging as intent matures.</div>
        <div class="pc-meta"><span>Draft preview</span></div>
      </article>
      {% endif %}
      {% if count < 3 %}
      <article class="post-card placeholder" data-cat="placeholder">
        <div class="pc-tag"><span class="pc-tag-dot"></span>Coming next</div>
        <div class="pc-title">Signal quality in outbound systems</div>
        <div class="pc-excerpt">Where targeting logic breaks before SDRs ever touch a lead.</div>
        <div class="pc-meta"><span>Draft preview</span></div>
      </article>
      {% endif %}
    </div>

    <div class="bottom-layout">
      <div class="bottom-posts">
        {% for post in collections.posts %}
        <a href="{{ post.url }}" class="post-card" data-title="{{ post.data.title | lower }}" data-cat="{{ (post.data.category or 'GTM') | lower | replace(' ', '-') }}">
          <div class="pc-tag"><span class="pc-tag-dot"></span>{{ post.data.category or 'GTM' }}</div>
          <div class="pc-title">{{ post.data.title }}</div>
          <div class="pc-excerpt">{{ post.data.description }}</div>
          <div class="pc-meta"><span>{{ post.date | postDate }} · {{ post.data.readTime }}</span><span class="pc-read">Read &#8594;</span></div>
        </a>
        {% endfor %}
        {% if collections.posts | length < 4 %}
        <article class="post-card placeholder" data-cat="placeholder">
          <div class="pc-tag"><span class="pc-tag-dot"></span>Coming next</div>
          <div class="pc-title">Diagnostic scoring methodology</div>
          <div class="pc-excerpt">How the assessment model scores ICP clarity across four signal layers.</div>
          <div class="pc-meta"><span>Draft preview</span></div>
        </article>
        {% endif %}
      </div>

      <div class="sidebar-cta">
        <p class="sc-kicker">Free diagnostic</p>
        <h4 class="sc-title">Name the GTM bottleneck before your next sprint.</h4>
        <p class="sc-body">Nine questions, four minutes, instant archetype + bottleneck output.</p>
        <a class="sc-btn" href="/assessment/">Run the assessment</a>
        <div class="sc-email-form">
          <input id="sc-email" type="email" placeholder="you@company.com" class="sc-input" required>
          <button type="submit" class="sc-submit" onclick="submitSidebar(event)">Notify me</button>
        </div>
      </div>
    </div>
  </div>
</section>
